# Database — PostgreSQL + pgvector (Supabase or self-hosted)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Auth — use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET="change-this-to-a-long-random-secret"

# Anthropic Claude API key — https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Python SymPy verifier sidecar URL (optional, falls back to numeric comparison)
SYMPY_VERIFIER_URL="http://localhost:8000"

# OpenAI GPT-4o Vision (Phase 5 Photo Solver)
OPENAI_API_KEY="sk-proj-..."

# Razorpay payments (Phase 5 — optional)
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."

# CORS — set to your frontend URL in production
CORS_ORIGIN="http://localhost:5173"

# Server
PORT=5000
